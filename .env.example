# Eval-runner credentials. Copy to `.env` and fill in:
#   cp .env.example .env
# `.env` is gitignored. NEVER commit the populated file.

# Cursor SDK auth — used by both the agent under test AND the judge.
# Mint a key at https://cursor.com/dashboard/cloud-agents.
CURSOR_API_KEY=

# Optional overrides — leave blank to use defaults.
# EVAL_AGENT_MODEL=composer-2
# EVAL_JUDGE_MODEL=claude-opus-4-7-thinking-max
# EVAL_JUDGE_THINKING_EFFORT=high
