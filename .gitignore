node_modules/
dist/
seeds/
*.tsbuildinfo
.DS_Store

# Secrets — NEVER commit. .env.example is the only tracked variant.
.env
.env.*
!.env.example

# Eval runs are gitignored — only baselines (evals/baselines/) are tracked.
evals/results/
evals/.tmp/

# Eval-fixture pollution: when an eval runs against a fixture, the agent
# may write into the fixture's runtime-local lanes (workspace/, memory/).
# These writes are craft / thought artifacts of the run, not part of the
# fixture's checked-in state — keep them out of git.
evals/fixtures/*/workspace/
evals/fixtures/*/memory/

# Harness artifacts — this repo is the plugin, not a harnessed project.
# If `/init-harness` is ever run here by accident, ignore its outputs so they
# don't pollute the plugin source tree. The canonical seed payload lives in
# `seed-sources/{knowledge,memory,workspace}/`.
/knowledge/
/memory/
/workspace/
/codebase/
/AGENTS.md
